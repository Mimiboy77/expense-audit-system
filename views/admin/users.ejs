<%- include('../partials/header') %>
<%- include('../partials/navbar') %>

<div class="page-container">
  <div class="page-header">
    <h2>Manage Users</h2>
    <a href="/admin" class="btn-secondary">← Admin Dashboard</a>
  </div>

  <!-- Search and filter -->
  <div class="detail-card" style="margin-bottom:24px;">
    <form action="/admin/users" method="GET" class="filter-form">

      <div class="form-group" style="margin:0; flex:2;">
        <label>Search</label>
        <input
          type="text"
          name="search"
          value="<%= filters.search || '' %>"
          placeholder="Search by name or email"
        />
      </div>

      <div class="form-group" style="margin:0; flex:1;">
        <label>Role</label>
        <select name="role">
          <option value="">All Roles</option>
          <option value="employee"
            <%= filters.role === 'employee' ? 'selected' : '' %>>
            Employee
          </option>
          <option value="manager"
            <%= filters.role === 'manager' ? 'selected' : '' %>>
            Manager
          </option>
          <option value="finance"
            <%= filters.role === 'finance' ? 'selected' : '' %>>
            Finance
          </option>
        </select>
      </div>

      <div class="form-group" style="margin:0; flex:1;">
        <label>Department</label>
        <select name="department">
          <option value="">All Departments</option>
          <% departments.forEach(dept => { %>
            <option value="<%= dept._id %>"
              <%= filters.department === dept._id.toString()
                ? 'selected' : '' %>>
              <%= dept.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div style="display:flex; gap:8px; align-items:flex-end;">
        <button type="submit" class="btn-primary">Search</button>
        <a href="/admin/users" class="btn-secondary"
          style="margin:0;">Clear</a>
      </div>
    </form>
  </div>

  <p style="color:#777; font-size:0.88rem; margin-bottom:16px;">
    Showing <%= users.length %> of <%= pagination.totalUsers %> users
  </p>

  <% if (users.length === 0) { %>
    <p class="empty-state">No users found.</p>
  <% } else { %>
    <table class="data-table">
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Role</th>
          <th>Department</th>
          <th>Joined</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% users.forEach(u => { %>
          <tr>
            <td><%= u.name %></td>
            <td><%= u.email %></td>
            <td>
              <span class="status-badge
                <%= u.role === 'finance'
                  ? 'status-approved'
                  : u.role === 'manager'
                  ? 'status-submitted'
                  : 'status-paid' %>">
                <%= u.role %>
              </span>
            </td>
            <td><%= u.department?.name || "N/A" %></td>
            <td>
              <%= new Date(u.createdAt).toLocaleDateString() %>
            </td>
            <td style="display:flex; gap:6px;">
              <a href="/admin/users/<%= u._id %>/edit"
                class="btn-small">Edit</a>

              <!-- Prevent deleting yourself -->
              <% if (u._id.toString() !== user._id.toString()) { %>
                <form
                  action="/admin/users/<%= u._id %>/delete"
                  method="POST"
                  onsubmit="return confirm('Are you sure you want to delete <%= u.name %>?')"
                >
                  <button type="submit"
                    class="btn-small"
                    style="background:#e94560;">
                    Delete
                  </button>
                </form>
              <% } %>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>

    <!-- Pagination -->
    <% if (pagination.totalPages > 1) { %>
      <div class="pagination">
        <% if (pagination.page > 1) { %>
          <a href="/admin/users?page=<%= pagination.page - 1 %>&search=<%= filters.search || '' %>&role=<%= filters.role || '' %>"
            class="btn-small">← Previous</a>
        <% } %>

        <span class="pagination-info">
          Page <%= pagination.page %> of <%= pagination.totalPages %>
        </span>

        <% if (pagination.page < pagination.totalPages) { %>
          <a href="/admin/users?page=<%= pagination.page + 1 %>&search=<%= filters.search || '' %>&role=<%= filters.role || '' %>"
            class="btn-small">Next →</a>
        <% } %>
      </div>
    <% } %>
  <% } %>
</div>

<%- include('../partials/footer') %>